{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "agentos-backend",
  "main": "src/index.ts",
  "compatibility_date": "2025-12-19",
  "compatibility_flags": ["nodejs_compat"],

  "triggers": {
    "crons": ["0 */6 * * *"]
  },

  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },

  "env": {
    "development": {
      "vars": {
        "ENVIRONMENT": "development",
        "FRONTEND_URL": "http://localhost:5173",
        "BACKEND_URL": "http://localhost:8787",
        "MIGRATE_SECRET": "tf-migrate-dev-2026"
      },
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "thread-forge-db",
          "database_id": "REPLACE_WITH_YOUR_D1_ID"
        }
      ],
      "r2_buckets": [
        {
          "binding": "ASSETS",
          "bucket_name": "thread-forge-assets",
          "preview_bucket_name": "thread-forge-assets"
        }
      ],
      "kv_namespaces": [
        {
          "binding": "KV",
          "id": "REPLACE_WITH_YOUR_KV_ID",
          "preview_id": "REPLACE_WITH_YOUR_KV_PREVIEW_ID"
        }
      ],
      "workflows": [
        {
          "name": "generation-workflow",
          "binding": "GENERATION_WORKFLOW",
          "class_name": "GenerationWorkflow"
        }
      ]
    }
  },

  "vars": {
    "ENVIRONMENT": "production",
    "FRONTEND_URL": "https://content-generation-chatbot.pages.dev",
    "BACKEND_URL": "https://agentos-backend.nadirhussain03000.workers.dev"
  },

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "content-gen",
      "database_id": "817de96b-2bb4-4b97-abbf-0250dada047d"
    }
  ],
  "r2_buckets": [
    {
      "binding": "ASSETS",
      "bucket_name": "content-gen",
      "preview_bucket_name": "content-gen"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "dd019f649ca94471823f631b1dfe5e85",
      "preview_id": "7833db39bc0445ff8458c219e56b0b28"
    }
  ],

  "workflows": [
    {
      "name": "generation-workflow",
      "binding": "GENERATION_WORKFLOW",
      "class_name": "GenerationWorkflow"
    }
  ]

  // Secrets (set via: wrangler secret put SECRET_NAME):
  // CLERK_SECRET_KEY
  // OPENAI_API_KEY
  // META_APP_ID
  // META_APP_SECRET
  // TIKTOK_APP_ID
  // TIKTOK_APP_SECRET
  // REPLICATE_API_TOKEN
  // SLACK_WEBHOOK_URL
}
